{
  "name": "showdown-replay-studio",
  "version": "1.1.0",
  "description": "Professional tool to record and download Pokemon Showdown replays.",
  "main": "main.js",
  "bin": "main.js",
  "scripts": {
    "start": "node main.js",
    "pkg": "pkg . --public",
    "build:win": "pkg . --targets node18-win-x64 --output dist/showdown-studio-win.exe --compress GZip",
    "build:mac": "pkg . --targets node18-mac-x64 --output dist/showdown-studio-mac --compress GZip",
    "bundle:mac": "node scripts/bundle_mac.js",
    "package:mac": "npm run build:mac && npm run bundle:mac",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/showdown-studio-linux --compress GZip",
    "build:all": "mkdir -p dist && npm run build:win && npm run build:mac && npm run bundle:mac && npm run build:linux"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/ffmpeg-static/**/*",
      "node_modules/puppeteer-stream/extension/**/*"
    ],
    "scripts": [],
    "outputPath": "dist"
  },
  "dependencies": {
    "express": "5.2.1",
    "ffmpeg-static": "5.3.0",
    "fluent-ffmpeg": "2.1.3",
    "open": "8.4.2",
    "puppeteer": "24.4.0",
    "puppeteer-core": "^24.4.0",
    "puppeteer-stream": "3.0.22",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "pkg": "5.8.1"
  }
}
